{
  "name": "token-eye",
  "version": "0.1.0",
  "description": "macOS menu bar monitor for LLM token usage across providers",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n vite,electron \"vite --port 5173 --strictPort\" \"sleep 3 && tsc -p tsconfig.electron.json && VITE_PORT=5173 electron .\"",
    "build:vite": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:vite && npm run build:electron",
    "pack": "npm run build && electron-builder --mac",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit"
  },
  "dependencies": {
    "json5": "^2.2.3",
    "menubar": "^9.5.2"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.2.0",
    "electron": "^36.0.0",
    "electron-builder": "^26.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0"
  },
  "build": {
    "appId": "com.token-eye.app",
    "productName": "Token Eye",
    "mac": {
      "target": "dmg",
      "icon": "public/icon.png",
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "dist/**/*",
      "providers.json"
    ]
  }
}
